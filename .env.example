# ═══════════════════════════════════════════════════════════
# ═══════════════════════════════════════════════════════════
# Copie este arquivo para .env.development (dev local) ou
# configure diretamente no painel da Vercel (produção).

# ── APP ───────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:5173
VITE_APP_URL=http://localhost:5173
VITE_API_URL=http://localhost:3001

# ── BANCO DE DADOS ───────────────────────────────────────
# Dev usa SQLite (zero-config), prod usa MySQL serverless.
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./dev.db

# ── AUTENTICAÇÃO ──────────────────────────────────────────
# Dev: BYPASS_AUTH=true (login automático, sem OAuth)
# Prod: remover BYPASS_AUTH, configurar GitHub OAuth abaixo
BYPASS_AUTH=true
JWT_SECRET=dev-secret-change-in-production-min-32-chars
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── STRIPE (pagamentos) ───────────────────────────────────
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder

# ── RATE LIMITING ─────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=900

# ── OWNER (opcional — define admin automático) ────────────
OWNER_OPEN_ID=
