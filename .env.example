# ═══════════════════════════════════════════════════════════
# BANCO DE DADOS — Prisma MySQL
# ═══════════════════════════════════════════════════════════
DATABASE_URL="mysql://user:password@localhost:3306/hubstry_compliance"

# ═══════════════════════════════════════════════════════════
# AUTENTICAÇÃO — NextAuth v5
# ═══════════════════════════════════════════════════════════
NEXTAUTH_SECRET="seu-secret-super-seguro-min-32-chars-123456789"
NEXTAUTH_URL="http://localhost:3000"

# OAuth - Google
GOOGLE_CLIENT_ID="seu-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu-google-client-secret"

# OAuth - GitHub (opcional)
GITHUB_CLIENT_ID="seu-github-client-id"
GITHUB_CLIENT_SECRET="seu-github-client-secret"

# ═══════════════════════════════════════════════════════════
# PAGAMENTOS — Stripe
# ═══════════════════════════════════════════════════════════
STRIPE_SECRET_KEY="sk_test_seu-stripe-secret-key"
STRIPE_PUBLISHABLE_KEY="pk_test_seu-stripe-publishable-key"
STRIPE_WEBHOOK_SECRET="whsec_seu-stripe-webhook-secret"

# IDs dos produtos Stripe (obter do dashboard)
STRIPE_PRODUCT_PRO_ID="price_sua-price-pro-id"
STRIPE_PRODUCT_ENTERPRISE_ID="price_sua-price-enterprise-id"

# ═══════════════════════════════════════════════════════════
# IA — OpenAI / Claude
# ═══════════════════════════════════════════════════════════
OPENAI_API_KEY="sk-proj-seu-openai-api-key"
LLM_MODEL="gpt-4-turbo"

# Ou para Claude:
# ANTHROPIC_API_KEY="sk-ant-seu-anthropic-api-key"
# LLM_MODEL="claude-3-sonnet"

# ═══════════════════════════════════════════════════════════
# ARMAZENAMENTO DE ARQUIVOS — AWS S3 ou local
# ═══════════════════════════════════════════════════════════
STORAGE_TYPE="local"  # ou "s3"

# Se usando S3:
AWS_REGION="sa-east-1"
AWS_ACCESS_KEY_ID="sua-aws-access-key"
AWS_SECRET_ACCESS_KEY="sua-aws-secret-key"
S3_BUCKET_NAME="hubstry-compliance-uploads"
S3_BUCKET_URL="https://seu-bucket.s3.amazonaws.com"

# ═══════════════════════════════════════════════════════════
# EMAIL — SendGrid ou SMTP
# ═══════════════════════════════════════════════════════════
SENDGRID_API_KEY="SG.seu-sendgrid-api-key"
EMAIL_FROM="noreply@hubstry.onmicrosoft.com"

# Ou SMTP:
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="seu-email@gmail.com"
SMTP_PASSWORD="sua-app-password"

# ═══════════════════════════════════════════════════════════
# OBSERVABILIDADE — Logging e Monitoring
# ═══════════════════════════════════════════════════════════
LOG_LEVEL="info"  # debug, info, warn, error
SENTRY_DSN="https://seu-sentry-dsn@sentry.io/project-id"
DATADOG_API_KEY="sua-datadog-api-key"

# ═══════════════════════════════════════════════════════════
# APP SETTINGS
# ═══════════════════════════════════════════════════════════
NODE_ENV="development"
APP_NAME="Hubstry Compliance"
APP_DESCRIPTION="Plataforma profissional de conformidade digital"
APP_URL="http://localhost:3000"
APP_SUPPORT_EMAIL="guilhermemachado@hubstry.onmicrosoft.com"

# ═══════════════════════════════════════════════════════════
# RATE LIMITING
# ═══════════════════════════════════════════════════════════
RATE_LIMIT_REQUESTS="100"
RATE_LIMIT_WINDOW="900"  # 15 minutos em segundos

# ═══════════════════════════════════════════════════════════
# CACHE (Redis ou em-memory)
# ═══════════════════════════════════════════════════════════
REDIS_URL="redis://localhost:6379"
CACHE_TTL="3600"  # 1 hora

# ═══════════════════════════════════════════════════════════
# SEGURANÇA
# ═══════════════════════════════════════════════════════════
ENABLE_SECURITY_HEADERS="true"
ENABLE_CORS="false"
CORS_ALLOWED_ORIGINS="http://localhost:3000,https://app.hubstry.com"

# ═══════════════════════════════════════════════════════════
# WEBHOOKS
# ═══════════════════════════════════════════════════════════
WEBHOOK_SECRET="seu-webhook-secret-key"
WEBHOOK_TIMEOUT="30000"  # ms
