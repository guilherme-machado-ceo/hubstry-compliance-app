// Hubstry Compliance — Prisma Database Schema
// Versão 1.0 — Configuração para MySQL
// Locale DB: pt-BR

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  // Seed command
  seed     = "node prisma/seed.ts"
}

// ═══════════════════════════════════════════════════════════
// ENUMS (Tipos)
// ═══════════════════════════════════════════════════════════

enum Role {
  SUPER_ADMIN          // Acesso completo ao sistema
  ADMIN                // Gerenciamento da organização
  COMPLIANCE_OFFICER   // Gerencia conformidade
  AUDITOR              // Realiza auditorias
  VIEWER               // Apenas visualização
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum ComplianceCategory {
  ANVISA
  FDA
  ISO_22000
  HACCP
  RDC
  CUSTOM
}

enum ChecklistStatus {
  DRAFT
  ACTIVE
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum DocumentType {
  LICENSE          // Licenças
  CERTIFICATE      // Certificados
  REPORT           // Relatórios
  MANUAL           // Manuais
  PROCEDURE        // Procedimentos
  EVIDENCE         // Evidências
  OTHER
}

enum DocumentStatus {
  ACTIVE           // Ativo e válido
  EXPIRED          // Vencido
  REVOKED          // Revogado
  PENDING_RENEWAL  // Pendente de renovação
}

enum AlertType {
  DOCUMENT_EXPIRY           // Documento vencedo em breve
  CHECKLIST_OVERDUE         // Checklist em atraso
  SCORE_BELOW_THRESHOLD     // Score abaixo do esperado
  NORMATIVE_CHANGE          // Mudança normativa
  SYSTEM                    // Alerta do sistema
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

// ═══════════════════════════════════════════════════════════
// MODELOS PRINCIPAIS
// ═══════════════════════════════════════════════════════════

/// Usuários da plataforma
model User {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  emailVerified   DateTime?
  image           String?
  password        String?  // Null se login social
  role            Role     @default(VIEWER)

  // Relacionamentos
  organization    Organization @relation(fields: [organizationId], references: [id])
  organizationId  String
  
  // Dados de auditoria
  auditLogs       AuditLog[]
  assignments     ChecklistAssignment[]
  assignedTasks   ChecklistAssignment[] @relation("AssignedBy")
  createdChecklists Checklist[] @relation("ChecklistCreator")
  uploadedDocuments Document[] @relation("DocumentUploader")
  CreatedAlerts   Alert[] @relation("AlertTriggeredBy")
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastLogin       DateTime?
  lastActivity    DateTime?

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

/// Organizações (empresas/clientes)
model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  logo        String?
  plan        Plan     @default(FREE)
  
  // Limite de recursos (Free: 3, Pro: unlimited, Enterprise: custom)
  maxScans    Int      @default(3)
  maxUsers    Int      @default(5)
  maxStorage  Int      @default(1000) // MB
  
  // Relacionamentos
  users       User[]
  checklists  Checklist[]
  documents   Document[]
  alerts      Alert[]
  
  // Settings
  timezone    String   @default("America/Sao_Paulo")
  language    String   @default("pt-BR")
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@map("organizations")
}

/// Checklists de conformidade
model Checklist {
  id              String    @id @default(cuid())
  title           String
  description     String?
  category        ComplianceCategory
  status          ChecklistStatus @default(DRAFT)
  
  // Dados de conformidade
  score           Float?           // 0-100
  completedAt     DateTime?
  dueDate         DateTime?
  
  // Relacionamentos
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String
  
  createdBy       User     @relation("ChecklistCreator", fields: [createdById], references: [id])
  createdById     String
  
  items           ChecklistItem[]
  assignments     ChecklistAssignment[]
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([organizationId])
  @@index([category])
  @@index([status])
  @@map("checklists")
}

/// Itens de um checklist
model ChecklistItem {
  id          String  @id @default(cuid())
  question    String
  description String?
  required    Boolean @default(true)
  order       Int
  
  // Relacionamentos
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  checklistId String
  responses   ChecklistResponse[]

  @@index([checklistId])
  @@map("checklist_items")
}

/// Respostas dos itens de checklist
model ChecklistResponse {
  id          String  @id @default(cuid())
  answer      Boolean
  notes       String?
  evidence    String? // URL do documento de evidência
  
  // Relacionamentos
  item        ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId      String
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([itemId])
  @@map("checklist_responses")
}

/// Atribuições de checklists aos usuários
model ChecklistAssignment {
  id          String    @id @default(cuid())
  
  // Relacionamentos
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  checklistId String
  
  assignedTo  User      @relation(fields: [assignedToId], references: [id])
  assignedToId String
  
  assignedBy  User      @relation("AssignedBy", fields: [assignedById], references: [id])
  assignedById String
  
  // Status da atribuição
  completedAt DateTime?
  
  createdAt   DateTime  @default(now())

  @@unique([checklistId, assignedToId])
  @@index([checklistId])
  @@index([assignedToId])
  @@map("checklist_assignments")
}

/// Documentos armazenados
model Document {
  id              String    @id @default(cuid())
  name            String
  type            DocumentType
  status          DocumentStatus @default(ACTIVE)
  
  // Armazenamento
  fileUrl         String
  fileKey         String   // Para S3 ou storage
  fileSize        Int      // em bytes
  mimeType        String
  
  // Metadados
  category        String?
  expiresAt       DateTime?
  renewal         DateTime? // Data de renovação sugerida
  
  // Relacionamentos
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String
  
  uploadedBy      User      @relation("DocumentUploader", fields: [uploadedById], references: [id])
  uploadedById    String
  
  // Versionamento
  version         Int       @default(1)
  previousVersion Document?  @relation("DocVersion", fields: [previousVersionId], references: [id])
  previousVersionId String?
  nextVersions    Document[] @relation("DocVersion")
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([organizationId])
  @@index([type])
  @@index([status])
  @@index([expiresAt])
  @@map("documents")
}

/// Alertas do sistema
model Alert {
  id              String    @id @default(cuid())
  type            AlertType
  title           String
  message         String
  severity        AlertSeverity @default(INFO)
  
  // Status
  isRead          Boolean   @default(false)
  readAt          DateTime?
  dismissedAt     DateTime?
  
  // Relacionamentos
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String
  
  triggeredBy     User?     @relation("AlertTriggeredBy", fields: [triggeredById], references: [id])
  triggeredById   String?
  
  // Metadados
  metadata        Json?     // Dados adicionais do alerta
  
  createdAt       DateTime  @default(now())

  @@index([organizationId])
  @@index([severity])
  @@index([isRead])
  @@index([createdAt])
  @@map("alerts")
}

/// Logs de auditoria do sistema
model AuditLog {
  id              String   @id @default(cuid())
  action          String   // ex: "create", "update", "delete"
  resource        String   // ex: "checklist", "document"
  resourceId      String?  // ID do recurso afetado
  
  // Dados da ação
  details         Json?    // Dados da mudança (old, new)
  status          String   // "success", "failure"
  errorMessage    String?
  
  // Contexto
  ipAddress       String?
  userAgent       String?
  
  // Relacionamentos
  user            User     @relation(fields: [userId], references: [id])
  userId          String
  
  // Timestamp
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([resource])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Conversas com IA
model AIConversation {
  id        String   @id @default(cuid())
  userId    String   // Usuário que criou (denorme não relacionado para flexibilidade)
  title     String?
  messages  Json     // Array de { role: "user"|"assistant", content: string }
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("ai_conversations")
}

/// Sessões de autenticação
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String   // Referência não com join para flexibilidade
  expires      DateTime
  
  createdAt    DateTime @default(now())

  @@index([sessionToken])
  @@map("sessions")
}

/// Tokens de verificação
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
