{
  "version": 2,
  "buildCommand": "prisma generate && vite build",
  "installCommand": "pnpm install",
  "framework": "vite",
  "outputDirectory": "dist",
  "functions": {
    "api/trpc/[trpc].ts": {
      "runtime": "@vercel/node@5.x"
    }
  },
  "rewrites": [
    { "source": "/api/trpc/:path*", "destination": "/api/trpc/[trpc]" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
